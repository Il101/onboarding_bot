# Application
APP_NAME=V-Brain
DEBUG=false

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://vbrain:vbrain@localhost:5432/vbrain

# Groq (Whisper API)
GROQ_API_KEY=

# Embeddings
DENSE_MODEL_NAME=intfloat/multilingual-e5-large
SPARSE_MODEL_NAME=Qdrant/bm42-all-MiniLM-L6-v2-quantized

# PII
PII_CONFIDENCE_THRESHOLD=0.5

# File storage
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=100

# Telegram grouping window (minutes)
TELEGRAM_GROUPING_WINDOW_MINUTES=30
