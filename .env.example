# Application
APP_NAME=V-Brain
DEBUG=false

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option 1: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
# LLM_BASE_URL=

# Option 2: Groq (free tier, fast)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Option 3: Ollama / local Gemma (no data leaves company)
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma3:27b
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=

# ── Infrastructure ────────────────────────────────────────────────────────────
# Knowledge API URL for LangGraph → FastAPI self-call
KNOWLEDGE_API_BASE_URL=http://localhost:8000

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://vbrain:vbrain@localhost:5432/vbrain

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate bcrypt hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ROLES={}

# ── Groq Whisper (voice transcription) ────────────────────────────────────────
GROQ_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────────
DENSE_MODEL_NAME=intfloat/multilingual-e5-large
SPARSE_MODEL_NAME=Qdrant/bm42-all-MiniLM-L6-v2-quantized

# ── PII ───────────────────────────────────────────────────────────────────────
PII_CONFIDENCE_THRESHOLD=0.5

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=100

# ── Telegram grouping ─────────────────────────────────────────────────────────
TELEGRAM_GROUPING_WINDOW_MINUTES=30
